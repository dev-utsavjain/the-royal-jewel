# Copy to .env and fill in. See config/config.go for all keys.

ENV=development
PORT=8080

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=royaljewel
DB_SCHEMA=public

# Auth — used to sign JWTs and seed the first admin on migration.
JWT_SECRET=change-me
ADMIN_EMAIL=admin@theroyaljewel.com
ADMIN_PASSWORD=royaljewel123

# MinIO / S3-compatible object storage for uploaded media.
# On Railway, point ENDPOINT at the private domain (minio.railway.internal:9000).
# Leave MINIO_ENDPOINT empty to disable uploads (dev without object storage).
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_USE_SSL=false
